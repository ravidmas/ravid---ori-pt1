<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp8.Pages.SignUpPage"
             BackgroundColor="Transparent"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <Image Source="guitar_background.jpg" Aspect="AspectFill" Opacity="1"/>
        <BoxView Color="{StaticResource AppOrange}" Opacity="0.6"/>

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="40" VerticalOptions="Center">

                <!-- Title -->
                <Label Text="🎵" FontSize="60" HorizontalOptions="Center"/>
                <Label Text="Create Account"
                       FontSize="36" FontAttributes="Bold"
                       TextColor="White" HorizontalOptions="Center"/>
                <Label Text="Start your guitar journey"
                       FontSize="16" TextColor="White" Opacity="0.8"
                       HorizontalOptions="Center" Margin="0,0,0,10"/>

                <!-- Sign Up Form -->
                <Frame BackgroundColor="{StaticResource AppCream}" CornerRadius="20"
                       Padding="25" HasShadow="True">
                    <VerticalStackLayout Spacing="15">

                        <Label Text="Display Name" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource AppDarkBrown}"/>
                        <Entry x:Name="NameEntry" Placeholder="Your name"
                               TextColor="{StaticResource AppDarkBrown}"
                               PlaceholderColor="{StaticResource Gray400}"
                               BackgroundColor="White" FontSize="16"/>

                        <Label Text="Email" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource AppDarkBrown}"/>
                        <Entry x:Name="EmailEntry" Placeholder="Your email"
                               Keyboard="Email" TextColor="{StaticResource AppDarkBrown}"
                               PlaceholderColor="{StaticResource Gray400}"
                               BackgroundColor="White" FontSize="16"/>

                        <Label Text="Password" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource AppDarkBrown}"/>
                        <Entry x:Name="PasswordEntry" Placeholder="Create a password"
                               IsPassword="True" TextColor="{StaticResource AppDarkBrown}"
                               PlaceholderColor="{StaticResource Gray400}"
                               BackgroundColor="White" FontSize="16"/>

                        <Label Text="Confirm Password" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource AppDarkBrown}"/>
                        <Entry x:Name="ConfirmPasswordEntry" Placeholder="Confirm your password"
                               IsPassword="True" TextColor="{StaticResource AppDarkBrown}"
                               PlaceholderColor="{StaticResource Gray400}"
                               BackgroundColor="White" FontSize="16"
                               ReturnType="Done" Completed="OnSignUpClicked"/>

                        <Label x:Name="ErrorLabel" Text="" TextColor="{StaticResource ErrorRed}"
                               FontSize="13" IsVisible="False" HorizontalOptions="Center"/>

                        <Button Text="Create Account"
                                BackgroundColor="{StaticResource AppBrown}"
                                TextColor="White" FontSize="18" FontAttributes="Bold"
                                CornerRadius="15" HeightRequest="50"
                                Clicked="OnSignUpClicked"/>

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                            <Label Text="Already have an account?" FontSize="14"
                                   TextColor="{StaticResource Gray500}" VerticalOptions="Center"/>
                            <Label Text="Sign In" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource AppBrown}" VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnBackToLoginTapped"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
