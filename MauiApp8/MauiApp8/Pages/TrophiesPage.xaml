<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp8.Pages.TrophiesPage"
             BackgroundColor="Transparent">

    <Grid>
        <!-- Background Image -->
        <Image Source="guitar_background.jpg"
               Aspect="AspectFill"
               Opacity="1"/>

        <!-- Orange Overlay -->
        <BoxView Color="{StaticResource AppOrange}"
                 Opacity="0.7"/>

        <!-- Main Content -->
        <Grid RowDefinitions="Auto,Auto,*"
              Padding="20">

            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,50,0,10">
                <Button Grid.Column="0"
                        Text="&#x2190; Back"
                        TextColor="White"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        AutomationId="BackButton"
                        Clicked="OnBackClicked"/>
                <Label Grid.Column="1"
                       Text="&#x1F3C6; Trophies"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Grid>

            <!-- Category Tabs -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,5,0,10">
                <Button x:Name="AllTab"
                        Text="All"
                        BackgroundColor="{StaticResource AppCream}"
                        TextColor="{StaticResource AppDarkBrown}"
                        FontAttributes="Bold"
                        CornerRadius="20"
                        FontSize="14"
                        Clicked="OnAllTabClicked"/>
                <Button x:Name="MilestoneTab"
                        Grid.Column="1"
                        Text="Milestones"
                        BackgroundColor="{StaticResource AppBrown}"
                        TextColor="White"
                        CornerRadius="20"
                        FontSize="14"
                        Opacity="0.7"
                        Clicked="OnMilestoneTabClicked"/>
                <Button x:Name="SkillTab"
                        Grid.Column="2"
                        Text="Skills"
                        BackgroundColor="{StaticResource AppBrown}"
                        TextColor="White"
                        CornerRadius="20"
                        FontSize="14"
                        Opacity="0.7"
                        Clicked="OnSkillTabClicked"/>
            </Grid>

            <!-- Trophies Grid -->
            <ScrollView Grid.Row="2">
                <VerticalStackLayout x:Name="TrophiesContainer"
                                   Spacing="12"
                                   Padding="0,0,0,30"/>
            </ScrollView>

        </Grid>
    </Grid>

</ContentPage>
