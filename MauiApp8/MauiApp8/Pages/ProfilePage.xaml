<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp8.Pages.ProfilePage"
             BackgroundColor="Transparent">

    <Grid>
        <!-- Background Image -->
        <Image Source="guitar_background.jpg"
               Aspect="AspectFill"
               Opacity="1"/>

        <!-- Orange Overlay -->
        <BoxView Color="{StaticResource AppOrange}"
                 Opacity="0.7"/>

        <!-- Main Content -->
        <Grid RowDefinitions="Auto,*"
              Padding="20">

            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,50,0,10">
                <Button Grid.Column="0"
                        Text="&#x2190; Back"
                        TextColor="White"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        AutomationId="BackButton"
                        Clicked="OnBackClicked"/>
                <Label Grid.Column="1"
                       Text="Profile"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Grid>

            <!-- Profile Content -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Spacing="15" Padding="0,10,0,30">

                    <!-- User Card -->
                    <Frame BackgroundColor="{StaticResource AppCream}"
                           CornerRadius="20"
                           Padding="25"
                           HasShadow="True">
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <!-- Avatar -->
                            <Frame BackgroundColor="{StaticResource AppBrown}"
                                   CornerRadius="50"
                                   WidthRequest="100"
                                   HeightRequest="100"
                                   Padding="0"
                                   HasShadow="False"
                                   HorizontalOptions="Center">
                                <Label x:Name="AvatarLabel"
                                       Text="&#x1F3B8;"
                                       FontSize="48"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Frame>
                            <Label x:Name="UserNameLabel"
                                   Text="Guitar Learner"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource AppDarkBrown}"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="JoinDateLabel"
                                   Text="Learning since today"
                                   FontSize="14"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Stats Cards -->
                    <Label Text="Your Stats"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           Margin="0,10,0,0"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <!-- Total Sessions -->
                        <Frame Grid.Column="0"
                               BackgroundColor="{StaticResource AppCream}"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="True">
                            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                                <Label Text="&#x1F3AF;"
                                       FontSize="32"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="TotalSessionsLabel"
                                       Text="0"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource AppBrown}"
                                       HorizontalOptions="Center"/>
                                <Label Text="Sessions"
                                       FontSize="13"
                                       TextColor="{StaticResource Gray500}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Accuracy -->
                        <Frame Grid.Column="1"
                               BackgroundColor="{StaticResource AppCream}"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="True">
                            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                                <Label Text="&#x2705;"
                                       FontSize="32"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="AccuracyLabel"
                                       Text="0%"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource SuccessGreen}"
                                       HorizontalOptions="Center"/>
                                <Label Text="Accuracy"
                                       FontSize="13"
                                       TextColor="{StaticResource Gray500}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <!-- Chords Learned -->
                        <Frame Grid.Column="0"
                               BackgroundColor="{StaticResource AppCream}"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="True">
                            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                                <Label Text="&#x1F3B5;"
                                       FontSize="32"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="ChordsLearnedLabel"
                                       Text="0"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource AppBrown}"
                                       HorizontalOptions="Center"/>
                                <Label Text="Chords"
                                       FontSize="13"
                                       TextColor="{StaticResource Gray500}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Streak -->
                        <Frame Grid.Column="1"
                               BackgroundColor="{StaticResource AppCream}"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="True">
                            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                                <Label Text="&#x1F525;"
                                       FontSize="32"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="StreakLabel"
                                       Text="0"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource AppOrange}"
                                       HorizontalOptions="Center"/>
                                <Label Text="Day Streak"
                                       FontSize="13"
                                       TextColor="{StaticResource Gray500}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <!-- Quick Actions -->
                    <Label Text="Quick Actions"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           Margin="0,10,0,0"/>

                    <!-- View Progress -->
                    <Frame BackgroundColor="{StaticResource AppCream}"
                           CornerRadius="15"
                           Padding="15"
                           HasShadow="True">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Label Grid.Column="0" Text="&#x1F4C8;" FontSize="28" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="View Progress" FontSize="18"
                                   TextColor="{StaticResource AppDarkBrown}" VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text="&#x25B6;" FontSize="20"
                                   TextColor="{StaticResource AppBrown}" VerticalOptions="Center"/>
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnViewProgressTapped"/>
                        </Frame.GestureRecognizers>
                    </Frame>

                    <!-- View Trophies -->
                    <Frame BackgroundColor="{StaticResource AppCream}"
                           CornerRadius="15"
                           Padding="15"
                           HasShadow="True">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Label Grid.Column="0" Text="&#x1F3C6;" FontSize="28" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Trophies" FontSize="18"
                                   TextColor="{StaticResource AppDarkBrown}" VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text="&#x25B6;" FontSize="20"
                                   TextColor="{StaticResource AppBrown}" VerticalOptions="Center"/>
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnViewTrophiesTapped"/>
                        </Frame.GestureRecognizers>
                    </Frame>

                </VerticalStackLayout>
            </ScrollView>

        </Grid>
    </Grid>

</ContentPage>
